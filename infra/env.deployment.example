# Copy this file to `.env` (same folder) for local development.
#
# Example:
#   cp infra/env.development.example infra/.env
#   docker compose --env-file infra/.env -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up --build

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=game_recommender_ai_db

# Backend (JVM)
JAVA_OPTS=-Xms256m -Xmx512m

# Backend URLs (used in application.properties)
APPLICATION_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173

# Backend security (JWT)
JWT_SECRET=dev_jwt_access_secret_change_me
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_me

# Cookies / CORS (used in application.properties)
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_MAX_AGE=3
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# gRPC
GRPC_AI_SERVICE_HOST=ai-service
GRPC_AI_SERVICE_PORT=9090

# Dev DB (R2DBC)
SPRING_DATASOURCE_URL=r2dbc:postgresql://game_recommender_ai_db:5432/game_recommender_ai_db?schema=game_recommender
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# Redis
REDIS_REDIS_URI=redis://redis:6379
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# Steam (required, used in application.properties)
STEAM_API_KEY=your_steam_api_key_here

# AI Service
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GIGACHAT_API_KEY=your_gigachat_api_key_here
GRPC_PORT=9090
HTTP_PORT=8000
