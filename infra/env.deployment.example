# Copy this file to `.env` (same folder) for local development.
#
# Example:
#   cp infra/env.development.example infra/.env
#   docker compose --env-file infra/.env -f infra/docker-compose.yml -f infra/docker-compose.dev.yml up --build

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=game_recommender_ai_db

# PG Admin
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Backend (JVM)
JAVA_OPTS=-Xms256m -Xmx512m
SPRING_APPLICATION_NAME=game-recommender-ai
SERVER_PORT=8080

# Backend URLs (used in application.yaml)
APPLICATION_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:5173

# Backend security (JWT)
JWT_SECRET=dev_jwt_access_secret_change_me
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_me

# Cookies / CORS (used in application.yaml)
REFRESH_TOKEN_COOKIE_NAME=refresh_token
COOKIE_MAX_AGE=3
COOKIE_SECURE=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# gRPC
GRPC_AI_SERVICE_HOST=ai-service
GRPC_AI_SERVICE_PORT=9090

# gRPC AI client (deadline / retries)
GRPC_AI_CLIENT_DEADLINE_SECONDS=20
GRPC_AI_CLIENT_RETRY_MAX_ATTEMPTS=1
GRPC_AI_CLIENT_RETRY_BACKOFF_MS=250

# gRPC AI Circuit Breaker
GRPC_AI_CB_NAME=grpcAi
GRPC_AI_CB_SLIDING_WINDOW_SIZE=10
GRPC_AI_CB_MINIMUM_NUMBER_OF_CALLS=10
GRPC_AI_CB_FAILURE_RATE_THRESHOLD=50.0
GRPC_AI_CB_WAIT_DURATION_OPEN_SECONDS=30
GRPC_AI_CB_PERMITTED_CALLS_IN_HALF_OPEN=2

# Dev DB (R2DBC + Liquibase)
SPRING_DATASOURCE_URL=r2dbc:postgresql://game-recommender-postgres-db:5432/game_recommender_ai_db?schema=game_recommender
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password
SPRING_LIQUIBASE_CHANGE_LOG=classpath:/db/changelog/changelog-master.xml
SPRING_LIQUIBASE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Redis
REDIS_REDIS_URI=redis://redis:6379
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
REDIS_BUCKET_KEY=steam-api-global-bucket
REDIS_CAPACITY=50
REDIS_TOKENS_PER_REFILL=10
REDIS_REFILL_DURATION=PT1S
REDIS_BUCKET_TTL=PT10M
REDIS_CACHE_KEY=steam_apps
REDIS_CACHE_STEAM_PROFILES_KEY=steam_profiles
REDIS_CACHE_USER_GAME_STATS_KEY=user_game_stats

# Steam (required, used in application.yaml)
STEAM_API_KEY=your_steam_api_key_here
STEAM_USER_SCHEME=https
STEAM_USER_HOST=api.steampowered.com
STEAM_USER_GET_PLAYER_SUMMARIES_PATH=/ISteamUser/GetPlayerSummaries/v0002/
STEAM_USER_GET_OWNED_GAMES_PATH=/IPlayerService/GetOwnedGames/v0001/
STEAM_USER_RETRY_ATTEMPTS=3
STEAM_USER_RETRY_DELAY_SECONDS=2
STEAM_STORE_SCHEME=https
STEAM_STORE_HOST=store.steampowered.com
STEAM_STORE_GET_APP_DETAILS_PATH=/api/appdetails
STEAM_STORE_RETRY_ATTEMPTS=10
STEAM_STORE_RETRY_DELAY_SECONDS=5
STEAM_API_SCHEME=https
STEAM_API_HOST=api.steampowered.com
STEAM_API_GET_APP_LIST_PATH=/ISteamApps/GetAppList/v2
STEAM_API_RETRY_ATTEMPTS=3
STEAM_API_RETRY_DELAY_SECONDS=10
STEAM_API_MAX_IN_MEMORY_SIZE=20971520
STEAM_API_DURATION_OF_MINUTES=3
STEAM_API_JITTER=0.5
STEAM_API_CONNECT_TIMEOUT_MILLIS=50000
STEAM_OPENID_ENDPOINT=https://steamcommunity.com/openid/login
STEAM_OPENID_TIMEOUT_SECONDS=5

# Scheduled tasks and batching / rate-limit
SCHEDULER_UPDATE_STEAM_APPS_CRON=0 0 2 ? * SUN
SCHEDULER_UPDATE_USER_DATA_CRON=0 0 */6 * * *
APP_BATCH_SIZE=10000
APP_BATCH_CONCURRENCY=8
RATE_LIMIT_GUEST_USER_PER_HOUR=5
RATE_LIMIT_USER_PER_HOUR=10

# Actuator
MANAGEMENT_ENDPOINTS_WEB_BASE_PATH=/actuator
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus,env,configprops
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_ENDPOINT_HEALTH_SHOW_COMPONENTS=always
MANAGEMENT_INFO_ENV_ENABLED=true
MANAGEMENT_INFO_GIT_ENABLED=true
MANAGEMENT_HEALTH_DEFAULTS_ENABLED=true
MANAGEMENT_HEALTH_DISKSPACE_ENABLED=true
MANAGEMENT_HEALTH_DB_ENABLED=true

# Metrics
MANAGEMENT_METRICS_HTTP_SERVER_REQUESTS_HISTOGRAM=true
MANAGEMENT_METRICS_TAG_APPLICATION=game-recommender-ai
MANAGEMENT_SIMPLE_METRICS_EXPORT_ENABLED=true
MANAGEMENT_PROMETHEUS_METRICS_EXPORT_ENABLED=true

# OpenAPI / Swagger
SWAGGER_ENABLED=false
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html
SPRINGDOC_SWAGGER_UI_ENABLED=false
SPRINGDOC_SWAGGER_UI_DISABLE_DEFAULT_URL=true
SPRINGDOC_SWAGGER_UI_PERSIST_AUTHORIZATION=true
SPRINGDOC_API_DOCS_PATH=/api-docs
SPRINGDOC_API_DOCS_ENABLED=false
SPRINGDOC_PATHS_TO_MATCH=/api/**

# Logging levels (backend)
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_GAMERECOMMENDER=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=DEBUG
LOGGING_LEVEL_IO_GRPC=DEBUG
LOGGING_LEVEL_IO_GRPC_INTERNAL_MANAGED_CHANNEL_IMPL_BUILDER=ERROR
LOGGING_LEVEL_IO_GRPC_INTERNAL=ERROR
LOGGING_LEVEL_IO_GRPC_MANAGED_CHANNEL_REGISTRY=ERROR
LOGGING_LEVEL_IO_GRPC_NETTY_SHADED_IO_GRPC_NETTY_UTILS=WARN
LOGGING_LEVEL_ORG_HIBERNATE=WARN
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=WARN
LOGGING_LEVEL_IO_GRPC_CONTEXT=ERROR
LOGGING_LEVEL_IO_GRPC_NETTY_SHADED_IO_GRPC_NETTY=INFO

# Request-id
REQUEST_ID_HEADER_KEY=rquid
REQUEST_ID_LOGGING_PARAM=RequestID

# AI Service
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GIGACHAT_API_KEY=your_gigachat_api_key_here
GRPC_PORT=9090
HTTP_PORT=8000