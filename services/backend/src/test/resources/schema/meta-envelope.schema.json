{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MetaEnvelope",
  "type": "object",
  "required": [
    "schemaVersion",
    "type",
    "payload"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "type": {
      "type": "string",
      "pattern": "^[a-z_]+$"
    },
    "payload": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
